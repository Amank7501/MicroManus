# MicroManus — environment variables
# Copy to .env.local and fill in values. Never commit .env.local.

# --- Phase 1: Supabase (auth, DB, key storage) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Phase 2: server-side credit grants (coupon redemption) ---
# Service role key bypasses Row Level Security — server-only, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Phase 3: encryption for user-supplied LLM API keys ---
# Any long random string (e.g. `openssl rand -hex 32`). Used to derive an
# AES-256-GCM key server-side — never sent to the client.
API_KEY_ENCRYPTION_SECRET=

# --- Phase 5: web search ---
# Free API key from https://app.tavily.com (no card required).
TAVILY_API_KEY=

# --- Phase 8: payments (Razorpay test mode) ---
# Key ID is not secret — it's also read by the browser to open the
# Checkout widget, hence the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Secret — server-only, used to create orders and verify payment signatures.
RAZORPAY_KEY_SECRET=
# Separate secret for verifying webhook deliveries (Dashboard → Webhooks).
RAZORPAY_WEBHOOK_SECRET=
